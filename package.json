{
  "name": "aktionstage-berlin",
  "version": "1.0.0",
  "description": "Hochschultage Berlin – Brave New World",
  "type": "module",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i src/css/styles.css -o dist/css/styles.css --minify",
    "build:html": "node build.js",
    "build": "npm run build:html && npm run build:css",
    "dev:css": "npx @tailwindcss/cli -i src/css/styles.css -o dist/css/styles.css --watch",
    "dev:html": "node build.js --watch",
    "dev": "npm run build:html && npm run dev:css"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
}
